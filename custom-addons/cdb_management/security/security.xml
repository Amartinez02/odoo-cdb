        <record id="module_category_church_management" model="ir.module.category">
            <field name="name">Church Management</field>
            <field name="description">Category for Church Management</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_church_user" model="res.groups">
            <field name="name">User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
