<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_church_activity_list" model="ir.ui.view">
        <field name="name">church.activity.list</field>
        <field name="model">church.activity</field>
        <field name="arch" type="xml">
            <list string="Activities">
                <field name="date"/>
                <field name="name"/>
                <field name="responsible_id"/>
            </list>
        </field>
    </record>

    <record id="view_church_activity_form" model="ir.ui.view">
        <field name="name">church.activity.form</field>
        <field name="model">church.activity</field>
        <field name="arch" type="xml">
            <form string="Activity">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej. Retiro Anual..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="responsible_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_church_activity" model="ir.actions.act_window">
        <field name="name">Yearly Activities</field>
        <field name="res_model">church.activity</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new church activity
            </p>
        </field>
    </record>

    <!-- Menu is placed in Configuration or Attendance root -->
    <menuitem id="menu_church_activity"
              name="Activities"
              parent="menu_church_config"
              action="action_church_activity"
              sequence="30"/>
</odoo>
