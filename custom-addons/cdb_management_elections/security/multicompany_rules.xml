<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ═══════════════════════════════════════════════════════════
             Multi-Company Record Rules — cdb_management_elections
             ═══════════════════════════════════════════════════════════ -->

        <!-- cdb.election -->
        <record id="rule_cdb_election_multicompany" model="ir.rule">
            <field name="name">CDB Election: multi-company</field>
            <field name="model_id" ref="model_cdb_election"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- cdb.election.position -->
        <record id="rule_cdb_election_position_multicompany" model="ir.rule">
            <field name="name">CDB Election Position: multi-company</field>
            <field name="model_id" ref="model_cdb_election_position"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- cdb.election.candidate -->
        <record id="rule_cdb_election_candidate_multicompany" model="ir.rule">
            <field name="name">CDB Election Candidate: multi-company</field>
            <field name="model_id" ref="model_cdb_election_candidate"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- cdb.election.vote.log -->
        <record id="rule_cdb_election_vote_log_multicompany" model="ir.rule">
            <field name="name">CDB Election Vote Log: multi-company</field>
            <field name="model_id" ref="model_cdb_election_vote_log"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

    </data>
</odoo>
